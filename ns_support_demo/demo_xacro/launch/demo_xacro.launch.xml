<launch>
  <let
    name="vehicle_group_2_string"
    value="$(command 'xacro $(find-pkg-share demo_xacro)/models/vehicle_group/model.sdf.xacro name:=vehicle_group_2')"/>
  <let
    name="vehicle_group_3_string"
    value="$(command 'xacro $(find-pkg-share demo_xacro)/models/vehicle_group/model.sdf.xacro name:=vehicle_group_3')"/>
  <gz_server
    world_sdf_file="$(find-pkg-share demo_xacro)/worlds/multi_robot.sdf"
    use_composition="False"
    create_own_container="False" />
  <node
    pkg="ros_gz_sim"
    exec="create"
    args="-world multi_robot
          -string $(var vehicle_group_2_string)
          -name vehicle_group_2
          -x 3.0
          -y 0.0
          -z 0.0
          -Y 0.0"
    output="screen" />
  <gz_spawn_model
    world="multi_robot"
    model_string="$(var vehicle_group_3_string)"
    entity_name="vehicle_group_3"
    allow_renaming="false"
    x="6.0"
    y="0.0"
    z="0.0"
    yaw="0.0"/>
  <executable cmd="gz sim -g" output="screen" />
</launch>
