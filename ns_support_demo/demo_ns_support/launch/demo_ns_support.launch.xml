<launch>
  <gz_server
    world_sdf_file="$(find-pkg-share demo_ns_support)/worlds/multi_robot.sdf"
    use_composition="True"
    create_own_container="True" />
  <node
    pkg="ros_gz_sim"
    exec="create"
    args="-world multi_robot
          -file $(find-pkg-share demo_ns_support)/models/vehicle_group/model.sdf
          -name vehicle_group_2
          -ns __name__
          -x 3.0
          -y 0.0
          -z 0.0
          -Y 0.0"
    output="screen" />
  <gz_spawn_model
    world="multi_robot"
    file="$(find-pkg-share demo_ns_support)/models/vehicle_group/model.sdf"
    entity_name="vehicle_group_3"
    entity_namespace="__name__"
    allow_renaming="false"
    x="6.0"
    y="0.0"
    z="0.0"
    yaw="0.0"/>
  <ros_gz_bridge
    bridge_name="ros_gz_bridge"
    config_file="$(find-pkg-share demo_ns_support)/config/bridge.yaml"
    use_composition="true"/>
  <executable cmd="gz sim -g" output="screen" />
</launch>
